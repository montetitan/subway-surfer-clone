<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <gradient
                android:angle="315"
                android:endColor="#1C2F4A"
                android:startColor="#2D4F77" />
        </shape>
    </item>

    <item android:top="10dp" android:bottom="10dp" android:left="10dp" android:right="10dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#0E1A30" />
        </shape>
    </item>

    <item android:top="24dp" android:bottom="24dp" android:left="20dp" android:right="20dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="#D62828" />
        </shape>
    </item>

    <item android:top="30dp" android:bottom="30dp" android:left="28dp" android:right="28dp">
        <shape android:shape="rectangle">
            <solid android:color="#90E0EF" />
        </shape>
    </item>

    <item android:top="40dp" android:bottom="16dp" android:left="22dp" android:right="22dp">
        <shape android:shape="rectangle">
            <corners android:radius="3dp" />
            <solid android:color="#FFD166" />
        </shape>
    </item>
</layer-list>
